# ddarahakit 배포(docker compose) 환경변수 템플릿
#   사용:  cp .env.example .env  후 값 채우기 (.env 는 git 미추적)
#   docker compose 가 자동으로 .env 를 읽어 ${VAR} 치환한다.

# ── DB (mariadb, 컨테이너 내부 전용 — 외부 미노출) ──────────────
# ※ 기존 데이터 볼륨(ddarahakit_mariadb_data)이 이미 이 값으로 초기화돼 있으면 동일 값 유지.
DB_ROOT_PASSWORD=root1234
DB_USER=ddarahakit
DB_PASSWORD=ddarahakit1234

# ── 보안 키 (운영 시 반드시 강한 임의값으로 교체) ──────────────
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_64_chars_long_for_HS512_xxxxxxxxxxxxxxxx
AES_SECRET_KEY=CHANGE_ME_32_chars_aes_key_12345   # 정확히 32자
SSL_KEY_STORE_PASSWORD=unused                      # TLS는 프록시에서 종단(백엔드 SSL off)

# ── OAuth2 (Google / Kakao 콘솔 값) ───────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://api.ddarahakit.com/login/oauth2/code/google
KAKAO_CLIENT_ID=CHANGE_ME
KAKAO_CLIENT_SECRET=CHANGE_ME
KAKAO_REDIRECT_URI=https://api.ddarahakit.com/login/oauth2/code/kakao

# ── 메일 (Gmail SMTP 앱 비밀번호) ─────────────────────────────
MAIL_ADDR=CHANGE_ME@gmail.com
MAIL_PASSWORD=CHANGE_ME_app_password

# ── 포트원 결제 ───────────────────────────────────────────────
PORTONE_SECRET=CHANGE_ME

# ── 강의 영상 디렉터리 (호스트 경로) → 프록시가 /videos/ 로 서빙 ──
# Windows 는 슬래시(/) 사용. Docker Desktop 에서 해당 드라이브 파일 공유 허용 필요.
VIDEO_DIR=G:/강의 녹화/강의 녹화

# ── 프론트엔드 빌드 주입값 (VITE_*) ───────────────────────────
# .env.production 을 git 에 두지 않으므로, 프론트 이미지 빌드 시 build-arg 로 주입한다.
# 주의: VITE_ 값은 클라이언트 번들에 인라인되어 공개된다(서버 비밀 금지).
#   - URL 류는 Dockerfile 기본값(api.ddarahakit.com)이 있어 생략 가능.
#   - 아래 3개는 환경별 식별자/키이므로 반드시 채울 것.
VITE_STORAGE_SECRET_KEY=CHANGE_ME_per_environment   # encrypt-storage 키(난독화용, 환경별 상이)
VITE_PORTONE_STORE_ID=store-CHANGE_ME               # 포트원 publishable Store ID(공개값)
VITE_PORTONE_CHANNEL_KEY=channel-key-CHANGE_ME      # 포트원 publishable 채널 키(공개값)
