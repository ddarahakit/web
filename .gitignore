# 루트 모노레포 .gitignore
# 각 하위 프로젝트(ddarahakit_backend, ddarahakit_frontend)의 .gitignore 가
# 빌드 산출물/비밀값(.env, keystore, node_modules 등)을 개별적으로 처리한다.

# OS
.DS_Store
Thumbs.db

# 에디터/IDE
.idea/
.vscode/
*.iml

# 로그
*.log

# 배포 비밀값/인증서 (.env.example 은 추적, 실제 .env 와 인증서는 미추적)
.env

# 배포 설정 폴더 전체 미추적 (깃헙에 올리지 않음)
deploy/

# 배포용 compose 파일 미추적 (깃헙에 올리지 않음)
docker-compose.yml
