# 로컬 도커 컴포즈용 프론트 이미지 — development 모드 빌드(브라우저가 로컬 백엔드 localhost:8080 호출).
# 정적 SPA 를 nginx 로 서빙한다. API/PortOne 설정은 빌드 ARG 로 주입한다.
#
# ※ 추적되는 .env.development 가 없고(.gitignore + .dockerignore 제외) 빌드 컨텍스트에도 안 들어오므로,
#    아래에서 이미지 내부에 .env.development 를 생성해 Vite(--mode development)가 읽게 한다.
# ===== 빌드 스테이지 =====
FROM node:20-alpine AS build
WORKDIR /app

# 의존성 설치 (lockfile 기반 재현 가능 설치)
COPY package.json package-lock.json ./
RUN npm ci

# 소스 복사
COPY . .

# 로컬 실행용 환경값 (모두 클라이언트 번들에 인라인되는 공개 값)
ARG VITE_API_BASE_URL=http://localhost:8080
ARG VITE_IMG_BASE_URL=http://localhost:8080
ARG VITE_PORTONE_STORE_ID=""
ARG VITE_PORTONE_CHANNEL_KEY=""
RUN printf 'VITE_BASE_URL="/"\nVITE_API_BASE_URL="%s"\nVITE_IMG_BASE_URL="%s"\nVITE_STORAGE_SECRET_KEY="secret-key-local"\nVITE_LOGIN_VALIDITY_TIME="86400000"\nVITE_LOGIN_EXTRA_TIME="60000"\nVITE_API_TIMEOUT="60000"\nVITE_PORTONE_STORE_ID="%s"\nVITE_PORTONE_CHANNEL_KEY="%s"\n' \
      "$VITE_API_BASE_URL" "$VITE_IMG_BASE_URL" "$VITE_PORTONE_STORE_ID" "$VITE_PORTONE_CHANNEL_KEY" > .env.development

RUN npm run build -- --mode development

# ===== 런타임 스테이지 =====
FROM nginx:1.27-alpine
COPY --from=build /app/dist /usr/share/nginx/html
# SPA 히스토리 라우팅 fallback
RUN printf 'server {\n  listen 80;\n  location / {\n    root /usr/share/nginx/html;\n    try_files $uri $uri/ /index.html;\n  }\n}\n' > /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
