# 프론트엔드 환경변수 예시 — 실제 값으로 채워 .env.development / .env.production 작성.
# 주의: VITE_ 접두어 변수는 빌드 시 클라이언트 번들에 인라인되어 공개된다.
#       따라서 서버 비밀(시크릿/프라이빗 키)은 절대 여기 두지 말 것.

# 라우터 base 경로
VITE_BASE_URL= "/"

# 백엔드 API / 이미지 베이스 URL
VITE_API_BASE_URL= "http://localhost:8080"
VITE_IMG_BASE_URL= "https://localhost:8080"

# encrypt-storage 암호화 키. 클라이언트 번들에 인라인되므로 "완전한 비밀"은 될 수 없고
# (난독화 수준), 환경별로 서로 다른 값을 사용한다. 운영값은 배포 파이프라인에서 주입 권장.
VITE_STORAGE_SECRET_KEY= "change-me-per-environment"

# 로그인 유효시간 / 만료 임박 알림 여유시간 / API 타임아웃 (ms)
VITE_LOGIN_VALIDITY_TIME= "86400000"
VITE_LOGIN_EXTRA_TIME= "60000"
VITE_API_TIMEOUT= "60000"

# PortOne 클라이언트(publishable) 식별자 — 브라우저에 노출되는 공개 값.
VITE_PORTONE_STORE_ID= "store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
VITE_PORTONE_CHANNEL_KEY= "channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
